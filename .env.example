# ── Operator (AEA/P Platform) ────────────────────────────────────────────
# Base URL of the Operator this agent talks to. Default: https://api.nustro.ai
OPERATOR_URL=https://api.nustro.ai
# No management key here — the provider authenticates its runtime economic
# calls (payment-address, facilitate) AS the agent, using the certificate
# below plus a request-bound proof (Operator Ref v1.2 §4.5).

# ── This agent (Provider / Sell-bot) ─────────────────────────────────────
PROVIDER_DID=did:aeap:your-agent-uuid-here
PROVIDER_BASE_URL=http://localhost:5001
# keys/private_key.pem + keys/certificate.jwt = this agent's key + cert.
# These ARE the runtime credential — keep them safe.

# ── Service + payment ────────────────────────────────────────────────────
# NOTE: the real settlement gate is the BUYER's country-derived market vs this
# provider's authorized_markets (must include {BUYER_COUNTRY}-USDC or GLOBAL-USDC).
# PAYMENT_MARKET below is only cosmetic on the 402 instructions.
PAYMENT_MARKET=US-USDC
PAYMENT_NETWORK=base-sepolia
SERVICE_PRICE=1000000
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/your-key-here
